[general]
# Error message locale ("ja" or "en")
error_message_locale = "ja"

[tokenizer]
# C11 strict mode (disables non-standard binary literals)
strict_c11 = false

# Trigraph replacement (??= etc.)
enable_trigraphs = true

# GNU-style binary integer literal support (0b...)
enable_binary_literals = true

# C11 audit mode for extension usage (logs when extension tokens are used)
enable_c11_audit_extensions = false

[parser]
# Allow same-size struct/union cast as a parser extension (non-standard)
enable_size_compatible_nonscalar_cast = true

# Allow scalar/pointer to struct value cast by lowering to first-member initialization
enable_struct_scalar_pointer_cast = true

# Allow scalar/pointer to union value cast by lowering to first-member initialization
enable_union_scalar_pointer_cast = true

# Allow non-brace initialization for union first array member (e.g. union U u={1,2};)
enable_union_array_member_nonbrace_init = true
